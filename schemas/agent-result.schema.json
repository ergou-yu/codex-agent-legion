{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/agent-legion/agent-result.schema.json",
  "title": "Codex Agent Legion Agent Result",
  "type": "object",
  "required": [
    "agent_id",
    "status",
    "summary",
    "changed_files",
    "verification",
    "risks"
  ],
  "properties": {
    "agent_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "completed",
        "partial",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "status"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "not_run"
            ]
          },
          "notes": {
            "type": "string"
          },
          "log_path": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
