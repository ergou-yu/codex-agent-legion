{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/agent-legion/review-finding.schema.json",
  "title": "Codex Agent Legion Review Finding",
  "type": "object",
  "required": [
    "severity",
    "title",
    "body"
  ],
  "properties": {
    "severity": {
      "enum": [
        "blocker",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "file": {
      "type": "string"
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "suggested_fix": {
      "type": "string"
    },
    "test_gap": {
      "type": "string"
    }
  }
}
